# Refuse to install package versions younger than 3 days (4320 minutes).
# Mitigates supply-chain attacks where a compromised release is yanked within hours.
# Requires npm >= 11.5.0; older clients silently ignore the key.
minimum-release-age=4320

@uipath:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
