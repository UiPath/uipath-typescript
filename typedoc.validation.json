{
  "$schema": "https://typedoc.org/schema.json",
  "extends": "./typedoc.json",
  "emit": "none",
  "validation": {
    "notDocumented": true,
    "notExported": false,
    "invalidLink": false
  },
  "requiredToBeDocumented": ["Method", "CallSignature", "Parameter"],
  "treatValidationWarningsAsErrors": true
}
